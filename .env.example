# ------------------------------------------------------------------------
# ThingsBoard CE - Dokploy environment
# Copy to .env locally for testing, OR set these in Dokploy UI (Environment)
# Do NOT commit the real .env (already gitignored)
# ------------------------------------------------------------------------

# --- Public domain (Traefik) ---
TB_DOMAIN=thingsboard.example.com

# --- PostgreSQL credentials ---
POSTGRES_DB=thingsboard
POSTGRES_USER=thingsboard
POSTGRES_PASSWORD=change-me-strong-password

# --- First-run install ---
# Set to true ONLY for the very first startup (creates schema + system data).
# Revert to false immediately after to avoid data loss on restart.
INSTALL_TB=false
# Load demo tenant/devices/dashboards. Keep false in production.
LOAD_DEMO=false

# --- JVM memory (tune for your VPS) ---
JAVA_OPTS=-Xms2g -Xmx4g

# ------------------------------------------------------------------------
# ChirpStack integration (reference only, configured in TB UI)
# ------------------------------------------------------------------------
# The tb container is attached to network 'chirpstack-server-chirpstack-r4wjat'
# so it can reach the ChirpStack MQTT broker privately.
#
# In TB UI -> Integrations -> Add (MQTT):
#   Host: <chirpstack-mosquitto-service-name>   (check: docker ps on that network)
#   Port: 1883
#   Topic filter: application/+/device/+/event/up
#   Converter: JS (parse ChirpStack uplink JSON -> deviceName + telemetry)
# ------------------------------------------------------------------------
